# ===========================================
# PrimeFlow AI Super Worker - Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- GoHighLevel API ---
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-location-id
GHL_BASE_URL=https://services.leadconnectorhq.com

# --- GHL OAuth (for Marketplace app) ---
GHL_CLIENT_ID=your-client-id
GHL_CLIENT_SECRET=your-client-secret
GHL_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Make.com ---
MAKE_API_KEY=your-make-api-key
MAKE_TEAM_ID=your-team-id
MAKE_BASE_URL=https://eu1.make.com/api/v2

# --- n8n ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/primeflow_ai
REDIS_URL=redis://localhost:6379/0

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# --- Browser Automation ---
HEADLESS=true
BROWSER_TIMEOUT=30000
