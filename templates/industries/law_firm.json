{
  "id": "law_firm",
  "name": "Law Firm",
  "name_he": "משרד עורכי דין",
  "description": "CRM for law firms — client intake, case management fields, consultation calendars, and professional communication templates.",
  "industries": ["law", "legal", "attorney", "lawyer", "עורך דין", "משפטי", "משרד עורכי דין"],
  "variables": {
    "business_name": {"description": "Firm name", "required": true},
    "owner_name": {"description": "Lead attorney name", "required": true},
    "owner_email": {"description": "Attorney email", "required": true},
    "owner_phone": {"description": "Office phone", "required": true},
    "second_user_name": {"description": "Second attorney/assistant", "required": false, "default": ""},
    "second_user_email": {"description": "Second user email", "required": false, "default": ""},
    "second_user_phone": {"description": "Second user phone", "required": false, "default": ""},
    "working_hours_start": {"description": "Start hour", "required": false, "default": "09:00"},
    "working_hours_end": {"description": "End hour", "required": false, "default": "18:00"},
    "working_days": {"description": "Working days", "required": false, "default": "sun-thu"}
  },
  "commands": [
    {"action": "create_tag", "name": "פנייה חדשה"},
    {"action": "create_tag", "name": "ייעוץ ראשוני"},
    {"action": "create_tag", "name": "לקוח פעיל"},
    {"action": "create_tag", "name": "תיק סגור"},
    {"action": "create_tag", "name": "אין מענה"},
    {"action": "create_tag", "name": "פולו אפ"},
    {"action": "create_tag", "name": "דיני עבודה"},
    {"action": "create_tag", "name": "נדלן"},
    {"action": "create_tag", "name": "דיני משפחה"},
    {"action": "create_tag", "name": "פלילי"},
    {"action": "create_tag", "name": "מסחרי"},
    {"action": "create_tag", "name": "נזיקין"},

    {"action": "create_custom_field", "name": "סטטוס תיק", "data_type": "SINGLE_OPTIONS",
     "options": ["פנייה חדשה", "ייעוץ ראשוני", "חתם על ייפוי כח", "בטיפול", "ממתין לתגובה", "תיק סגור"]},
    {"action": "create_custom_field", "name": "תחום משפטי", "data_type": "SINGLE_OPTIONS",
     "options": ["דיני עבודה", "נדלן", "דיני משפחה", "פלילי", "מסחרי", "נזיקין", "הוצאה לפועל", "אחר"]},
    {"action": "create_custom_field", "name": "שכר טרחה", "data_type": "MONETORY"},
    {"action": "create_custom_field", "name": "תאריך ייעוץ ראשוני", "data_type": "DATE"},
    {"action": "create_custom_field", "name": "צד נגדי", "data_type": "TEXT"},
    {"action": "create_custom_field", "name": "מספר תיק בית משפט", "data_type": "TEXT"},
    {"action": "create_custom_field", "name": "מקור הפניה", "data_type": "SINGLE_OPTIONS",
     "options": ["גוגל", "המלצה", "אתר", "לשכת עורכי הדין", "פייסבוק", "אחר"]},
    {"action": "create_custom_field", "name": "הערות עו\"ד", "data_type": "LARGE_TEXT"},
    {"action": "create_custom_field", "name": "דחיפות", "data_type": "SINGLE_OPTIONS",
     "options": ["דחוף", "רגיל", "נמוכה"]},

    {"action": "create_template", "name": "ברוכים הבאים - משרד", "type": "sms",
     "body": "שלום {{contact.first_name}}, תודה שפנית ל{{business_name}}. נחזור אליך בהקדם לתיאום ייעוץ ראשוני. לכל שאלה - השב להודעה זו."},
    {"action": "create_template", "name": "התראת פנייה חדשה", "type": "sms",
     "body": "🔔 פנייה חדשה! שם: {{contact.first_name}} {{contact.last_name}} | טלפון: {{contact.phone}}"},
    {"action": "create_template", "name": "תזכורת ייעוץ", "type": "sms",
     "body": "שלום {{contact.first_name}}, רק מזכירים שיש לך ייעוץ מתוכנן ב{{business_name}}. מחכים לך!"},
    {"action": "create_template", "name": "פולו אפ משפטי", "type": "sms",
     "body": "שלום {{contact.first_name}}, לא הצלחנו ליצור איתך קשר. האם עדיין צריך עזרה משפטית? נשמח לסייע. {{business_name}}"},

    {"action": "create_user", "first_name": "{{owner_first_name}}", "last_name": "{{owner_last_name}}",
     "email": "{{owner_email}}", "phone": "{{owner_phone}}", "role": "admin"},
    {"action": "create_user", "first_name": "{{second_user_first_name}}", "last_name": "{{second_user_last_name}}",
     "email": "{{second_user_email}}", "phone": "{{second_user_phone}}", "role": "user"},

    {"action": "create_calendar", "name": "ייעוץ ראשוני - {{owner_first_name}}", "calendarType": "personal",
     "slotDuration": 45, "description": "לוח ייעוצים - {{owner_first_name}} {{owner_last_name}}",
     "_availability": {"start": "{{working_hours_start}}", "end": "{{working_hours_end}}", "days": "{{working_days}}"}}
  ]
}
